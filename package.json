  "scripts": {
    "ng": "nx",
    "start": "nx serve --open",
    "start:web": "nx serve web --open",
    "clean-start:web": "nx serve web --open --port=0",
    "clean-start:web-p3000": "nx serve web --open --port=3000",
    "clean-stage:web": "nx serve web --configuration=staging --open --port=0",
    "clean-prod:web": "nx serve web ---prod --open --port=0",
    "build:web": "nx build web --prod --build-optimizer",
    "build:web-ssr": "nx build web --prod && nx run web:server:production",
    "build-stage:web": "nx build web --configuration=staging --build-optimizer --output-path=dist-stage/apps/web",
    "build-stage:web-ssr": "nx build webapp --configuration=staging --output-path=dist-stage/apps/web && nx run web:server-stage:staging"
  },
