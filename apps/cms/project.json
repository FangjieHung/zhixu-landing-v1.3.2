{
  "name": "cms",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "chuhung-angular16-apps",
  "sourceRoot": "apps/cms/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/cms",
        "index": "apps/cms/src/index.html",
        "main": "apps/cms/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/cms/tsconfig.app.json",
        "assets": [
          "apps/cms/src/favicon.ico",
          "apps/cms/src/assets",
          {
            "input": "./libs/core/src/assets",
            "glob": "**/*",
            "output": "assets/shared"
          }
        ],
        "styles": [
          "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
          "./node_modules/ng-zorro-antd/ng-zorro-antd.min.css",
          "./node_modules/ngx-spinner/animations/ball-spin-clockwise.css",
          "apps/cms/src/styles.scss"
        ],
        "scripts": [],
        "allowedCommonJsDependencies": [
          "enum-values",
          "linqts",
          "quill",
          "form-data"
        ]
      },
      "configurations": {
        "staging": {
          "budgets": [],
          "fileReplacements": [
            {
              "replace": "apps/cms/src/environments/environment.ts",
              "with": "apps/cms/src/environments/environment.staging.ts"
            }
          ],
          "outputHashing": "all"
        },
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "3mb",
              "maximumError": "5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "3kb",
              "maximumError": "5kb"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/cms/src/environments/environment.ts",
              "with": "apps/cms/src/environments/environment.prod.ts"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "browserTarget": "cms:build:production"
        },
        "staging": {
          "browserTarget": "cms:build:staging"
        },
        "development": {
          "browserTarget": "cms:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "cms:build"
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/cms/**/*.ts", "apps/cms/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/cms/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "cms:build"
      }
    }
  }
}
